{
  "extends": "@tsconfig/react-native/tsconfig.json" /* Recommended React Native TSConfig base */,
  "compilerOptions": {
    "types": ["node", "jest"],
    "isolatedModules": true,
    "composite": true,
    "allowJs": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "jsx": "react-native",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "logic": ["../logic/src/index.ts"],
      "logic/*": ["../logic/src/*"],
      "models": ["../models/src/index.ts"],
      "models/*": ["../models/src/*"],
      "shared": ["../shared/src/index.ts"],
      "shared/*": ["../shared/src/*"]
    }
  },
  "exclude": [".bundle", "android", "ios", "node_modules", "vendor"]
}
