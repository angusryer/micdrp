{
  "name": "client",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "react-native start --reset-cache",
    "android:production": "react-native run-android --mode release",
    "android:staging": "react-native run-android --mode staging",
    "android:development": "react-native run-android --mode debug",
    "ios:production": "react-native run-ios --scheme micdrp",
    "ios:staging": "react-native run-ios --scheme micdrp-staging",
    "ios:development": "react-native run-ios --scheme micdrp-development",
    "pod": "cd ios && bundle exec pod install",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@shopify/react-native-skia": "^1.5.0",
    "@supabase/supabase-js": "^2.45.4",
    "@xstate/react": "^3.1.2",
    "cross-env": "^7.0.3",
    "i18next": "^23.15.1",
    "logic": "workspace:*",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-i18next": "^15.0.2",
    "react-native": "^0.72.4",
    "react-native-audio-api": "^0.12.2",
    "react-native-config": "^1.5.0",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.18.1",
    "react-native-keychain": "^8.2.0",
    "react-native-localize": "^3.2.1",
    "react-native-mmkv": "^2.12.2",
    "react-native-reanimated": "^3.15.0",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-screens": "^3.34.0",
    "react-native-share": "^10.2.1",
    "react-native-url-polyfill": "^2.0.0",
    "shared": "workspace:*",
    "xstate": "^4.35.4"
  }
}
